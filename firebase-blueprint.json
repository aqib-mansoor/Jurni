{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User's personal information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "birthDate": { "type": "string" },
        "nationality": { "type": "string" },
        "memberSince": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "preferences": {
          "type": "object",
          "properties": {
            "language": { "type": "string" },
            "currency": { "type": "string" },
            "travelStyle": { "type": "string" },
            "notifications": {
              "type": "object",
              "properties": {
                "email": { "type": "boolean" },
                "push": { "type": "boolean" },
                "sms": { "type": "boolean" }
              }
            }
          }
        },
        "loyaltyPoints": { "type": "number" }
      },
      "required": ["uid", "email", "displayName", "memberSince", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "A user's review for a listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "listingId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "listingId", "rating", "comment", "createdAt"]
    },
    "Listing": {
      "title": "Listing",
      "description": "A travel experience or accommodation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["flight", "train", "hotel", "villa", "adventure", "wellness"] },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "host": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "photoURL": { "type": "string" },
            "verified": { "type": "boolean" },
            "responseRate": { "type": "string" },
            "languages": { "type": "array", "items": { "type": "string" } }
          }
        },
        "availability": {
          "type": "object",
          "properties": {
            "bookedDates": { "type": "array", "items": { "type": "string" } },
            "maxGuests": { "type": "number" },
            "lowStockThreshold": { "type": "number" }
          }
        },
        "featured": { "type": "boolean" },
        "trending": { "type": "boolean" }
      },
      "required": ["id", "title", "location", "price", "type", "host", "availability"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A user's booking for a listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "listingId": { "type": "string" },
        "listingSummary": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "location": { "type": "string" },
            "image": { "type": "string" }
          }
        },
        "dates": {
          "type": "object",
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" }
          }
        },
        "guests": {
          "type": "object",
          "properties": {
            "adults": { "type": "number" },
            "children": { "type": "number" },
            "infants": { "type": "number" }
          }
        },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "passengerManifest": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string" },
              "phone": { "type": "string" }
            }
          }
        },
        "specialRequests": { "type": "string" },
        "paymentMethodId": { "type": "string" }
      },
      "required": ["id", "userId", "listingId", "dates", "guests", "totalPrice", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["booking", "offer", "wishlist", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "text", "createdAt"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A concierge chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "number" }
      },
      "required": ["id", "userId", "status", "lastMessageAt", "unreadCount"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A listing saved to a user's wishlist.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "listingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "listingId", "createdAt"]
    },
    "InternalConnectionTest": {
      "title": "Internal Connection Test",
      "description": "Used to verify Firestore connectivity.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Available travel listings."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "User bookings."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "User reviews for listings."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    },
    "/chat_sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Concierge chat sessions."
    },
    "/chat_sessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat session."
    },
    "/wishlists/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User wishlist items."
    },
    "/_internal/{id}": {
      "schema": "InternalConnectionTest",
      "description": "Internal collection for connectivity tests."
    }
  }
}
